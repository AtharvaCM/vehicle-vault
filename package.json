{
  "name": "vehicle-vault",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @vehicle-vault/shared --filter @vehicle-vault/api --filter @vehicle-vault/web run dev",
    "dev:web": "pnpm --filter @vehicle-vault/web run dev",
    "dev:api": "pnpm --filter @vehicle-vault/api run dev",
    "db:generate": "pnpm --filter @vehicle-vault/api run prisma:generate",
    "db:migrate": "pnpm --filter @vehicle-vault/api run prisma:migrate",
    "db:deploy": "pnpm --filter @vehicle-vault/api run prisma:deploy",
    "db:seed": "pnpm --filter @vehicle-vault/api run prisma:seed",
    "catalog:import:hyundai-india": "pnpm --filter @vehicle-vault/api run catalog:import:hyundai-india",
    "db:studio": "pnpm --filter @vehicle-vault/api run prisma:studio",
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "test:e2e:web": "pnpm --filter @vehicle-vault/web run test:e2e",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "clean": "pnpm -r --if-present run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "vitest": "^4.1.0"
  }
}
