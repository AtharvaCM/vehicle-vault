PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_PATTERN=
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vehicle_vault?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/vehicle_vault?schema=public
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=vehicle-vault-attachments
JWT_SECRET=vehicle-vault-dev-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=vehicle-vault-dev-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# AI Integration
GEMINI_API_KEY=your-gemini-api-key-from-ai-studio
GEMINI_MODEL=gemini-2.5-flash

# OAuth (Google + GitHub). Leave unset to disable a provider; the login
# page will hide the corresponding button automatically.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/oauth/google/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/oauth/github/callback
# Where the API redirects after the provider hands the user back. Defaults to
# {FRONTEND_ORIGIN}/auth/oauth-callback when unset.
OAUTH_FRONTEND_REDIRECT_URL=
