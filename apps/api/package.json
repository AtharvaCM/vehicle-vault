{
  "name": "@vehicle-vault/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @vehicle-vault/shared build && pnpm exec prisma generate --schema prisma/schema.prisma",
    "dev": "nest start --watch",
    "prebuild": "pnpm --filter @vehicle-vault/shared build && pnpm exec prisma generate --schema prisma/schema.prisma",
    "build": "nest build",
    "start": "node dist/src/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "pretypecheck": "pnpm --filter @vehicle-vault/shared build && pnpm exec prisma generate --schema prisma/schema.prisma",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm --filter @vehicle-vault/shared build && pnpm exec prisma generate --schema prisma/schema.prisma",
    "test": "vitest run --config vitest.config.ts",
    "format": "prettier --check \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "prisma:seed": "ts-node --project tsconfig.json --transpile-only prisma/seed.ts",
    "catalog:import:all": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=all",
    "catalog:import:bajaj-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=bajaj-india",
    "catalog:import:hero-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=hero-india",
    "catalog:import:honda-cars-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=honda-cars-india",
    "catalog:import:hyundai-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=hyundai-india",
    "catalog:import:kia-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=kia-india",
    "catalog:import:mahindra-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=mahindra-india",
    "catalog:import:maruti-suzuki-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=maruti-suzuki-india",
    "catalog:import:renault-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=renault-india",
    "catalog:import:royal-enfield-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=royal-enfield-india",
    "catalog:import:skoda-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=skoda-india",
    "catalog:import:tata-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=tata-india",
    "catalog:import:toyota-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=toyota-india",
    "catalog:import:tvs-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=tvs-india",
    "catalog:import:volkswagen-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=volkswagen-india",
    "catalog:import:yamaha-india": "ts-node --project tsconfig.json --transpile-only prisma/import-catalog.ts --source=yamaha-india",
    "catalog:sync-aliases": "ts-node --project tsconfig.json --transpile-only prisma/sync-catalog-aliases.ts",
    "catalog:scrape": "ts-node --project tsconfig.json --transpile-only prisma/catalog-import/scraper/scrape-carwale.ts",
    "catalog:seed-specs": "ts-node --project tsconfig.json --transpile-only prisma/catalog-import/scraper/upsert-specs.ts",
    "catalog:scrape-specs": "ts-node --project tsconfig.json --transpile-only prisma/catalog-import/scraper/scrape-specs.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.11",
    "@prisma/client": "^6.18.0",
    "@supabase/supabase-js": "^2.99.3",
    "@vehicle-vault/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nodemailer": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vehicle-vault/config": "workspace:*",
    "cheerio": "^1.2.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "puppeteer": "^24.40.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2"
  }
}
