NODE_ENV=production
PORT=3001

# Set this to the browser frontend origin once the web app is deployed.
FRONTEND_ORIGIN=https://your-frontend-domain.example

# Supabase Postgres pooler connection used by the running API.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

# Prisma migrate deploy also works with the pooler in this setup.
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
