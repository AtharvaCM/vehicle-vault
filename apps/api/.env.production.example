NODE_ENV=production
PORT=3001

# Set this to the browser frontend origin. You can provide a comma-separated
# allowlist during a domain transition.
FRONTEND_ORIGIN=https://vehicle-vault-eight.vercel.app

# Optional regex for preview deployments, for example:
# ^https://vehicle-vault.*\.vercel\.app$
FRONTEND_ORIGIN_PATTERN=

# Supabase Postgres pooler connection used by the running API.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

# Prisma migrate deploy also works with the pooler in this setup.
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=vehicle-vault-attachments

JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Either provide a full SMTP connection URL or set the host/port/user/pass fields below.
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Vehicle Vault <no-reply@vehiclevault.middle-earth.in>
MAIL_REPLY_TO=
