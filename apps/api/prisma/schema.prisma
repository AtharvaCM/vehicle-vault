generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FuelType {
  petrol
  diesel
  electric
  hybrid
  cng
  lpg
  other
}

enum VehicleType {
  car
  motorcycle
  suv
  truck
  van
  other
}

enum MaintenanceCategory {
  periodic_service
  engine_oil
  oil_filter
  air_filter
  brake_pads
  tyre_rotation
  wheel_alignment
  battery
  coolant
  clutch
  chain_service
  tyre_replacement
  puncture
  insurance
  puc
  other
}

enum MaintenanceSource {
  manual
  ocr
  csv
  api
}

enum MaintenanceRecordStatus {
  draft
  confirmed
}

enum MaintenanceLineItemKind {
  job
  part
  fluid
  labor
  fee
  tax
  discount
  other
}

enum ReminderType {
  service
  insurance
  puc
  tyre_rotation
  battery
  custom
}

enum ReminderStatus {
  upcoming
  due_today
  overdue
  completed
}

enum AttachmentKind {
  receipt
  document
  image
  other
}

enum AttachmentExtractionStatus {
  pending
  completed
  failed
}

enum CatalogImportRunStatus {
  running
  succeeded
  failed
}

model Vehicle {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String              @db.Uuid
  registrationNumber String              @db.VarChar(20)
  make               String              @db.VarChar(80)
  model              String              @db.VarChar(80)
  variant            String              @db.VarChar(80)
  year               Int
  fuelType           FuelType
  odometer           Int
  vehicleType        VehicleType
  nickname           String?             @db.VarChar(80)
  catalogVariantId   String?             @db.Uuid
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogVariant     VehicleCatalogVariant? @relation(fields: [catalogVariantId], references: [id], onDelete: SetNull)
  maintenanceRecords MaintenanceRecord[]
  reminders          Reminder[]
  fuelLogs           FuelLog[]
  insurancePolicies  InsurancePolicy[]
  warranties         Warranty[]

  @@unique([userId, registrationNumber])
  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([catalogVariantId])
}

model VehicleCatalogMake {
  id          String                   @id @default(uuid()) @db.Uuid
  marketCode  String                   @db.VarChar(2)
  vehicleType VehicleType
  name        String                   @db.VarChar(120)
  slug        String                   @db.VarChar(160)
  sourceName  String?                  @db.VarChar(80)
  sourceUrl   String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  aliases     VehicleCatalogMakeAlias[]
  models      VehicleCatalogModel[]

  @@unique([marketCode, vehicleType, slug])
  @@index([marketCode, vehicleType, name])
}

model VehicleCatalogModel {
  id          String                    @id @default(uuid()) @db.Uuid
  makeId      String                    @db.Uuid
  name        String                    @db.VarChar(120)
  slug        String                    @db.VarChar(160)
  sourceName  String?                   @db.VarChar(80)
  sourceUrl   String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  aliases     VehicleCatalogModelAlias[]
  make        VehicleCatalogMake        @relation(fields: [makeId], references: [id], onDelete: Cascade)
  generations VehicleCatalogGeneration[]

  @@unique([makeId, slug])
  @@index([makeId, name])
}

model VehicleCatalogGeneration {
  id         String                 @id @default(uuid()) @db.Uuid
  modelId     String                 @db.Uuid
  name        String                 @db.VarChar(160)
  slug        String                 @db.VarChar(200)
  yearStart   Int?
  yearEnd     Int?
  isCurrent   Boolean                @default(false)
  sourceName  String?                @db.VarChar(80)
  sourceUrl   String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  aliases     VehicleCatalogGenerationAlias[]
  model       VehicleCatalogModel    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  variants    VehicleCatalogVariant[]

  @@unique([modelId, slug])
  @@index([modelId, name])
  @@index([modelId, yearStart, yearEnd])
}

model VehicleCatalogVariant {
  id                String                                @id @default(uuid()) @db.Uuid
  generationId      String                                @db.Uuid
  name              String                                @db.VarChar(160)
  slug              String                                @db.VarChar(200)
  sourceName        String?                               @db.VarChar(80)
  sourceUrl         String?
  createdAt         DateTime                              @default(now())
  updatedAt         DateTime                              @updatedAt
  aliases           VehicleCatalogVariantAlias[]
  generation        VehicleCatalogGeneration              @relation(fields: [generationId], references: [id], onDelete: Cascade)
  offerings         VehicleCatalogVariantOffering[]
  offeringOverrides VehicleCatalogVariantOfferingOverride[]
  spec              VehicleCatalogVariantSpec?
  vehicles          Vehicle[]
  serviceIntervals  ServiceInterval[]

  @@unique([generationId, slug])
  @@index([generationId, name])
}

model VehicleCatalogVariantSpec {
  id                String   @id @default(uuid()) @db.Uuid
  variantId         String   @unique @db.Uuid

  // Engine & Drivetrain
  engineCc          Int?
  engineCyl         Int?
  engineType        String?  @db.VarChar(60)
  engineFuel        String?  @db.VarChar(60)
  powerPs           Float?
  powerRpm          Int?
  torqueNm          Float?
  torqueRpm         Int?
  transmission      String?  @db.VarChar(80)
  driveType         String?  @db.VarChar(40)

  // Dimensions & Weight
  lengthMm          Int?
  widthMm           Int?
  heightMm          Int?
  wheelbaseMm       Int?
  kerbWeightKg      Int?
  grossWeightKg     Int?
  bootSpaceLitres   Int?
  groundClearanceMm Int?
  turningRadiusM    Float?

  // Performance & Economy
  topSpeedKph       Int?
  mileageCity       Float?
  mileageHighway    Float?
  mileageCombined   Float?
  fuelCapLitres     Float?

  // Body & Comfort
  seatingCapacity   Int?
  bodyType          String?  @db.VarChar(40)
  doors             Int?

  // Tyres & Wheels
  tyreSize          String?  @db.VarChar(60)
  wheelType         String?  @db.VarChar(40)
  wheelSizeInch     Float?

  // Safety
  airbagCount       Int?
  safetyFeatures    String?

  sourceName        String?  @db.VarChar(80)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  variant           VehicleCatalogVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model VehicleCatalogMakeAlias {
  id              String             @id @default(uuid()) @db.Uuid
  makeId          String             @db.Uuid
  alias           String             @db.VarChar(160)
  normalizedAlias String             @db.VarChar(160)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  make            VehicleCatalogMake @relation(fields: [makeId], references: [id], onDelete: Cascade)

  @@unique([makeId, normalizedAlias])
  @@index([normalizedAlias])
}

model VehicleCatalogModelAlias {
  id              String              @id @default(uuid()) @db.Uuid
  modelId         String              @db.Uuid
  alias           String              @db.VarChar(160)
  normalizedAlias String              @db.VarChar(160)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  model           VehicleCatalogModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, normalizedAlias])
  @@index([normalizedAlias])
}

model VehicleCatalogGenerationAlias {
  id              String                   @id @default(uuid()) @db.Uuid
  generationId    String                   @db.Uuid
  alias           String                   @db.VarChar(180)
  normalizedAlias String                   @db.VarChar(180)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  generation      VehicleCatalogGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@unique([generationId, normalizedAlias])
  @@index([normalizedAlias])
}

model VehicleCatalogVariantAlias {
  id              String                @id @default(uuid()) @db.Uuid
  variantId       String                @db.Uuid
  alias           String                @db.VarChar(180)
  normalizedAlias String                @db.VarChar(180)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  variant         VehicleCatalogVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, normalizedAlias])
  @@index([normalizedAlias])
}

model VehicleCatalogVariantOffering {
  id         String                @id @default(uuid()) @db.Uuid
  variantId  String                @db.Uuid
  fuelTypes  FuelType[]
  yearStart  Int?
  yearEnd    Int?
  isCurrent  Boolean               @default(false)
  sourceName String?               @db.VarChar(80)
  sourceUrl  String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  variant    VehicleCatalogVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, yearStart, yearEnd])
  @@index([variantId, isCurrent])
}

model VehicleCatalogVariantOfferingOverride {
  id                String                @id @default(uuid()) @db.Uuid
  variantId         String                @db.Uuid
  sourceName        String                @db.VarChar(80)
  fuelTypeSignature String                @db.VarChar(80)
  reviewNote        String?
  manualYearStart   Int?
  manualYearEnd     Int?
  manualIsCurrent   Boolean?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  variant           VehicleCatalogVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, sourceName, fuelTypeSignature])
  @@index([sourceName])
}

model VehicleCatalogImportRun {
  id              String                   @id @default(uuid()) @db.Uuid
  sourceKey       String                   @db.VarChar(80)
  marketCode      String                   @db.VarChar(2)
  status          CatalogImportRunStatus
  publishedAt     DateTime?
  publishedByUserId String?                @db.Uuid
  startedAt       DateTime                 @default(now())
  completedAt     DateTime?
  snapshotCount   Int                      @default(0)
  recordsUpserted Int                      @default(0)
  recordsArchived Int                      @default(0)
  notes           String?
  publishedBy     User?                    @relation("CatalogImportPublishes", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  snapshots       VehicleCatalogImportSnapshot[]

  @@index([marketCode, sourceKey, startedAt(sort: Desc)])
  @@index([marketCode, sourceKey, publishedAt(sort: Desc)])
}

model VehicleCatalogImportSnapshot {
  id         String                 @id @default(uuid()) @db.Uuid
  importRunId String                @db.Uuid
  sourceUrl  String
  sourceHash String                 @db.Char(64)
  payload    Json
  capturedAt DateTime               @default(now())
  importRun  VehicleCatalogImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId, capturedAt(sort: Desc)])
}

model User {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(120)
  email            String    @unique @db.VarChar(255)
  passwordHash     String    @db.VarChar(255)
  passwordResetTokenExpiresAt DateTime?
  passwordResetTokenHash      String?   @db.Char(64)
  refreshTokenHash String?   @db.Char(64)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  emailVerified    Boolean   @default(false)
  emailVerificationTokenHash String? @db.Char(64)
  allowedCatalogSources String[] @default([])
  publishedCatalogImportRuns VehicleCatalogImportRun[] @relation("CatalogImportPublishes")
  vehicles         Vehicle[]
  notifications    Notification[]
}

model MaintenanceRecord {
  id              String              @id @default(uuid()) @db.Uuid
  vehicleId       String              @db.Uuid
  serviceDate     DateTime
  odometer        Int
  category        MaintenanceCategory
  workshopName    String?             @db.VarChar(120)
  invoiceNumber   String?             @db.VarChar(120)
  currencyCode    String              @default("INR") @db.VarChar(3)
  source          MaintenanceSource   @default(manual)
  status          MaintenanceRecordStatus @default(confirmed)
  totalCost       Decimal             @db.Decimal(12, 2)
  laborCost       Decimal?            @db.Decimal(12, 2)
  partsCost       Decimal?            @db.Decimal(12, 2)
  fluidsCost      Decimal?            @db.Decimal(12, 2)
  taxCost         Decimal?            @db.Decimal(12, 2)
  discountAmount  Decimal?            @db.Decimal(12, 2)
  notes           String?
  metadata        Json?
  nextDueDate     DateTime?
  nextDueOdometer Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  vehicle         Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  attachments     Attachment[]
  lineItems       MaintenanceLineItem[]

  @@index([vehicleId, serviceDate(sort: Desc)])
  @@index([vehicleId, status, serviceDate(sort: Desc)])
  @@index([vehicleId, invoiceNumber])
}

model MaintenanceLineItem {
  id                  String                  @id @default(uuid()) @db.Uuid
  maintenanceRecordId String                  @db.Uuid
  kind                MaintenanceLineItemKind
  name                String                  @db.VarChar(160)
  normalizedCategory  MaintenanceCategory?
  quantity            Decimal?                @db.Decimal(10, 2)
  unit                String?                 @db.VarChar(24)
  unitPrice           Decimal?                @db.Decimal(12, 2)
  lineTotal           Decimal?                @db.Decimal(12, 2)
  brand               String?                 @db.VarChar(80)
  partNumber          String?                 @db.VarChar(80)
  notes               String?
  position            Int                     @default(0)
  metadata            Json?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  maintenanceRecord   MaintenanceRecord       @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)

  @@index([maintenanceRecordId, position])
  @@index([maintenanceRecordId, kind])
  @@index([normalizedCategory])
}

model Reminder {
  id          String         @id @default(uuid()) @db.Uuid
  vehicleId   String         @db.Uuid
  title       String         @db.VarChar(120)
  type        ReminderType
  dueDate     DateTime?
  dueOdometer Int?
  status      ReminderStatus
  completedAt DateTime?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  vehicle     Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, createdAt(sort: Desc)])
  @@index([status, dueDate])
}

model Attachment {
  id                  String            @id @default(uuid()) @db.Uuid
  maintenanceRecordId String            @db.Uuid
  kind                AttachmentKind
  fileName            String
  originalFileName    String
  mimeType            String
  size                Int
  url                 String
  uploadedAt          DateTime          @default(now())
  maintenanceRecord   MaintenanceRecord @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)
  extraction          AttachmentExtraction?

  @@index([maintenanceRecordId, uploadedAt(sort: Desc)])
}

model AttachmentExtraction {
  id            String                   @id @default(uuid()) @db.Uuid
  attachmentId  String                   @unique @db.Uuid
  status        AttachmentExtractionStatus @default(pending)
  provider      String?                  @db.VarChar(40)
  confidence    Decimal?                 @db.Decimal(4, 3)
  vendorName    String?                  @db.VarChar(120)
  workshopName  String?                  @db.VarChar(120)
  invoiceNumber String?                  @db.VarChar(120)
  documentDate  DateTime?
  serviceDate   DateTime?
  odometer      Int?
  totalCost     Decimal?                 @db.Decimal(12, 2)
  currencyCode  String?                  @db.VarChar(3)
  notes         String?
  lineItems     Json?
  failureReason String?
  extractedAt   DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  attachment    Attachment               @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@index([status, extractedAt(sort: Desc)])
}

model FuelLog {
  id          String   @id @default(uuid()) @db.Uuid
  vehicleId   String   @db.Uuid
  date        DateTime
  odometer    Int
  quantity    Float    // Litres/Gallons
  price       Decimal  @db.Decimal(10, 2)
  totalCost   Decimal  @db.Decimal(12, 2)
  location    String?  @db.VarChar(120)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, date(sort: Desc)])
}

model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  vehicleId   String?  @db.Uuid
  title       String   @db.VarChar(120)
  message     String   @db.Text
  type        String   @default("info") // info, warning, success, error
  isRead      Boolean  @default(false)
  link        String?  // Optional path to redirect to
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
}
 
model ServiceInterval {
  id                String                @id @default(uuid()) @db.Uuid
  variantId         String                @db.Uuid
  category          MaintenanceCategory
  intervalKm        Int?
  intervalMonths    Int?
  priority          String                @default("medium") // low, medium, high
  notes             String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  variant           VehicleCatalogVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
 
  @@index([variantId])
}

model InsurancePolicy {
  id              String   @id @default(uuid()) @db.Uuid
  vehicleId       String   @db.Uuid
  provider        String   @db.VarChar(120)
  policyNumber    String   @db.VarChar(80)
  startDate       DateTime
  endDate         DateTime
  premiumAmount   Decimal? @db.Decimal(12, 2)
  insuredValue    Decimal? @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, endDate])
}

model Warranty {
  id              String   @id @default(uuid()) @db.Uuid
  vehicleId       String   @db.Uuid
  provider        String   @db.VarChar(120)
  warrantyNumber  String?  @db.VarChar(80)
  type            String   @db.VarChar(60) // manufacturer, extended, parts
  startDate       DateTime
  endDate         DateTime?
  endOdometer     Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}
